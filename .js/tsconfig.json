{
  "compilerOptions": {
    "rootDir": "../",
    "outDir": "./dist/",
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types"],
    "paths": {
      "*": ["./node_modules/*"]
    },
    "moduleResolution": "bundler",
    "module": "esnext",
    "moduleDetection": "force",
    "allowJs": true,

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "exclude": [
    "node_modules"
  ]
}
